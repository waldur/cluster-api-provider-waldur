# Copy to waldur-controller-config.env and fill in values.
# VAULT_ADDR and VAULT_K8S_ROLE are optional — omit to disable Vault integration.
VAULT_ADDR=http://vault.default.svc.cluster.local:8200
VAULT_K8S_ROLE=waldur-capi-controller
# BASE_TEMPLATE_CONFIGMAP is optional — name of a ConfigMap with a cloud-init.yaml key.
#BASE_TEMPLATE_CONFIGMAP=cloud-init-base
